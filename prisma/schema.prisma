generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  clerkUserId  String   @unique
  email        String   @unique
  firstName    String?
  lastName     String?
  profileImage String?
  phoneNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Flight {
  id               String   @id @default(uuid())
  flightName       String
  flightDate       String
  flightTime       String
  flightImages     String[]
  airlineName      String
  economySeats     Int
  businessSeats    Int
  firstClassSeats  Int
  economyPrice     Float
  businessPrice    Float
  firstClassPrice  Float
  departureAirport String
  arrivalAirport   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Banner {
  id                 String  @id @default(uuid())
  title              String
  description        String?
  destinationAirport String
  largeImageUrl      String
  smallImageUrl      String
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
